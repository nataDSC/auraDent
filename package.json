{
  "name": "auradent",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/aws"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace @auradent/web",
    "dev:gateway": "npm run dev --workspace @auradent/gateway",
    "readback:worker-local": "npm run readback:local --workspace @auradent/worker",
    "run:worker-local": "npm run run:local --workspace @auradent/worker",
    "migrate:worker-local": "npm run migrate:local --workspace @auradent/worker",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
